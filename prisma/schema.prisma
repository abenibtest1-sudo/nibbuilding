generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Building {
  id                       String                     @id @default(cuid())
  name                     String                     @unique
  address                  String?
  ownerName                String?
  ownerPhone               String?
  ownerEmail               String?
  ownerAddress             String?
  branchName               String
  accountNumber            String
  status                   BuildingStatus             @default(Pending)
  rejectionReason          String?
  createdAt                DateTime                   @default(now())
  updatedAt                DateTime?                  @updatedAt
  createdById              String?
  approvedById             String?
  Agreement                Agreement[]
  AgreementTemplate        AgreementTemplate[]
  auditLogs                AuditLog[]
  approvedBy               User?                      @relation("ApprovedBuildings", fields: [approvedById], references: [id])
  createdBy                User?                      @relation("CreatedBuildings", fields: [createdById], references: [id])
  buildingMonthlyUtilities BuildingMonthlyUtilities[]
  penaltyPolicyTiers       PenaltyTier[]
  spaces                   Space[]
  Tenant                   Tenant[]
  tenantStatuses           TenantBuildingStatus[]
  TenantMessage            TenantMessage[]
  managers                 User[]                     @relation("ManagedBuildings")
}

model Space {
  id                    String         @id @default(cuid())
  buildingId            String
  buildingName          String
  status                BuildingStatus @default(Active)
  rejectionReason       String?
  spaceIdName           String
  area                  Decimal        @db.Decimal(10, 2)
  floor                 String
  utilityProrationShare Decimal        @default(0) @db.Decimal(5, 4)
  monthlyRentalPrice    Decimal        @db.Decimal(12, 2)
  isOccupied            Boolean        @default(false)
  createdAt             DateTime       @default(now())
  updatedAt             DateTime?      @updatedAt
  createdById           String?
  approvedById          String?
  agreements            Agreement[]
  approvedBy            User?          @relation("ApprovedSpaces", fields: [approvedById], references: [id])
  building              Building       @relation(fields: [buildingId], references: [id])
  createdBy             User?          @relation("CreatedSpaces", fields: [createdById], references: [id])
  tenant                Tenant?
}

model Tenant {
  id                  String                 @id @default(cuid())
  name                String
  email               String                 @unique
  phone               String                 @unique
  alternativePhone    String?
  nationalId          String?                @unique
  representativeName  String?
  representativePhone String?
  status              TenantStatus           @default(Active)
  createdAt           DateTime               @default(now())
  updatedAt           DateTime?              @updatedAt
  userId              String?                @unique
  rentedSpaceId       String?                @unique
  buildingId          String?
  createdById         String?
  agreements          Agreement[]
  bills               Bill[]
  building            Building?              @relation(fields: [buildingId], references: [id])
  createdBy           User?                  @relation("CreatedTenants", fields: [createdById], references: [id])
  rentedSpace         Space?                 @relation(fields: [rentedSpaceId], references: [id])
  user                User?                  @relation("TenantProfile", fields: [userId], references: [id])
  buildingStatuses    TenantBuildingStatus[]
  messages            TenantMessage[]
}

model TenantMessage {
  id         String    @id @default(cuid())
  tenantId   String
  buildingId String
  subject    String?
  body       String
  createdAt  DateTime  @default(now())
  readAt     DateTime?
  building   Building  @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([buildingId, createdAt])
  @@index([tenantId, createdAt])
}

model TenantBuildingStatus {
  id         String       @id @default(cuid())
  tenantId   String
  buildingId String
  status     TenantStatus @default(Active)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime?    @updatedAt
  building   Building     @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  tenant     Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, buildingId])
}

model Agreement {
  id                   String            @id @default(cuid())
  tenantId             String
  spaceId              String
  agreementTemplateId  String
  agreementText        String
  startDate            DateTime          @db.Date
  monthlyRentalPrice   Decimal           @db.Decimal(12, 2)
  additionalTerms      String?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  createdById          String?
  approvedById         String?
  rejectionReason      String?
  paymentTermMonths    Int
  initialPaymentMonths Int
  nextPaymentDueDate   DateTime          @db.Date
  status               AgreementStatus   @default(Active)
  initialPaymentAmount Decimal?
  initialPaymentDate   DateTime?         @db.Date
  endDate              DateTime?         @db.Date
  buildingId           String?
  agreementTemplate    AgreementTemplate @relation(fields: [agreementTemplateId], references: [id])
  approvedBy           User?             @relation("ApprovedAgreements", fields: [approvedById], references: [id])
  building             Building?         @relation(fields: [buildingId], references: [id])
  createdBy            User?             @relation("CreatedAgreements", fields: [createdById], references: [id])
  space                Space             @relation(fields: [spaceId], references: [id])
  tenant               Tenant            @relation(fields: [tenantId], references: [id])
  ArifPayment          ArifPayment[]
  bills                Bill[]
}

model AgreementTemplate {
  id          String      @id @default(cuid())
  name        String
  content     String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime?   @updatedAt
  createdById String?
  buildingId  String?
  Agreement   Agreement[]
  building    Building?   @relation(fields: [buildingId], references: [id])
  createdBy   User?       @relation("CreatedTemplates", fields: [createdById], references: [id])
}

model Bill {
  id                     String     @id @default(cuid())
  agreementId            String
  tenantId               String
  billDate               DateTime
  dueDate                DateTime
  rentAmount             Decimal    @db.Decimal(12, 2)
  utilityBreakdown       Json       @default("[]")
  penaltyAmount          Decimal?   @db.Decimal(12, 2)
  totalAmount            Decimal    @db.Decimal(12, 2)
  status                 BillStatus @default(Pending)
  paymentDate            DateTime?
  paymentMethod          String?
  paymentReference       String?
  bankOrWalletName       String?
  paymentProofDataUri    String?
  tenantPaymentNotes     String?
  adminVerifiedPayment   Boolean?   @default(false)
  isPrepaid              Boolean?   @default(false)
  adminVerificationNotes String?
  createdAt              DateTime   @default(now())
  updatedAt              DateTime?  @updatedAt
  agreement              Agreement  @relation(fields: [agreementId], references: [id], onDelete: Cascade)
  tenant                 Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  yagoutPayments         YagoutPayment[]
}

model BuildingMonthlyUtilities {
  id              String                @id @default(cuid())
  buildingId      String
  buildingName    String
  year            Int
  month           Int
  status          BuildingStatus        @default(Active)
  rejectionReason String?
  createdById     String?
  approvedById    String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime?             @updatedAt
  approvedBy      User?                 @relation("ApprovedBuildingMonthlyUtilities", fields: [approvedById], references: [id])
  building        Building              @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  createdBy       User?                 @relation("CreatedBuildingMonthlyUtilities", fields: [createdById], references: [id])
  utilities       BuildingUtilityItem[]

  @@unique([buildingId, year, month])
}

model BuildingUtilityItem {
  id                     String                    @id @default(cuid())
  name                   String
  totalCost              Decimal                   @db.Decimal(12, 2)
  appliesToScope         String
  applicableFloor        String?
  applicableSpaceIdNames String[]
  perSpaceAllocation     String?
  monthlyUtilitiesId     String?
  monthlyUtilities       BuildingMonthlyUtilities? @relation(fields: [monthlyUtilitiesId], references: [id], onDelete: Cascade)
}

model PenaltyTier {
  id                     String    @id @default(cuid())
  fromDay                Int
  toDay                  Int?
  penaltyType            String
  feeValue               Decimal   @db.Decimal(12, 2)
  frequency              String    @default("OneTime")
  scope                  String    @default("Building")
  applicableFloor        String?
  applicableSpaceIdNames String[]
  buildingId             String?
  building               Building? @relation(fields: [buildingId], references: [id], onDelete: Cascade)
}

model ChangeRequest {
  id              String              @id @default(cuid())
  resourceType    String
  resourceId      String
  payload         Json
  status          ChangeRequestStatus @default(Pending)
  requestedById   String?
  reviewedById    String?
  rejectionReason String?
  createdAt       DateTime            @default(now())
  reviewedAt      DateTime?
  requestedBy     User?               @relation("RequestedByChangeRequests", fields: [requestedById], references: [id])
  reviewedBy      User?               @relation("ReviewedByChangeRequests", fields: [reviewedById], references: [id])

  @@index([resourceType, resourceId])
}

model User {
  id                               String                     @id @default(cuid())
  name                             String?
  firstName                        String?
  lastName                         String?
  email                            String                     @unique
  phoneNumber                      String                     @unique
  status                           UserStatus                 @default(Active)
  showAllBuildings                 Boolean                    @default(false)
  canSeeSuperAdminRoles            Boolean                    @default(false)
  canAssignBuildings               Boolean                    @default(false)
  showAllUsers                     Boolean                    @default(false)
  nibBranch                        String?
  password                         String?
  tempPassword                     String?
  createdAt                        DateTime                   @default(now())
  updatedAt                        DateTime?                  @updatedAt
  createdById                      String?
  approvedAgreements               Agreement[]                @relation("ApprovedAgreements")
  createdAgreements                Agreement[]                @relation("CreatedAgreements")
  createdTemplates                 AgreementTemplate[]        @relation("CreatedTemplates")
  AuditLog                         AuditLog[]
  approvedBuildings                Building[]                 @relation("ApprovedBuildings")
  createdBuildings                 Building[]                 @relation("CreatedBuildings")
  approvedBuildingMonthlyUtilities BuildingMonthlyUtilities[] @relation("ApprovedBuildingMonthlyUtilities")
  createdBuildingMonthlyUtilities  BuildingMonthlyUtilities[] @relation("CreatedBuildingMonthlyUtilities")
  requestedChangeRequests          ChangeRequest[]            @relation("RequestedByChangeRequests")
  reviewedChangeRequests           ChangeRequest[]            @relation("ReviewedByChangeRequests")
  createdRoles                     Role[]                     @relation("CreatedRoles")
  approvedSpaces                   Space[]                    @relation("ApprovedSpaces")
  createdSpaces                    Space[]                    @relation("CreatedSpaces")
  createdTenants                   Tenant[]                   @relation("CreatedTenants")
  tenantProfile                    Tenant?                    @relation("TenantProfile")
  createdBy                        User?                      @relation("CreatedBy", fields: [createdById], references: [id])
  createdUsers                     User[]                     @relation("CreatedBy")
  UserSession                      UserSession[]
  managedBuildings                 Building[]                 @relation("ManagedBuildings")
  roles                            Role[]                     @relation("UserRoles")
}

model ApplicationSetting {
  id                    String    @id @default("global")
  billDateConfiguration Int?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime? @updatedAt
}

model Role {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  permissions String[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime? @updatedAt
  createdById String?
  createdBy   User?     @relation("CreatedRoles", fields: [createdById], references: [id])
  users       User[]    @relation("UserRoles")
}

model RateLimit {
  id             String   @id @default(cuid())
  identifier     String   @unique
  attempts       Int
  firstAttemptAt DateTime
}

model AuditLog {
  id              String   @id @default(cuid())
  actorId         String?
  actorName       String
  action          String
  tenantId        String
  tenantName      String
  buildingId      String
  buildingName    String
  spaceName       String
  paymentDate     DateTime
  rentAmount      Decimal  @db.Decimal(12, 2)
  utilityAmount   Decimal  @db.Decimal(12, 2)
  penaltyAmount   Decimal  @db.Decimal(12, 2)
  totalAmount     Decimal  @db.Decimal(12, 2)
  transactionId   String?
  toAccountNumber String
  createdAt       DateTime @default(now())
  actor           User?    @relation(fields: [actorId], references: [id], onDelete: Restrict)
  building        Building @relation(fields: [buildingId], references: [id])
}

model UserSession {
  id         String    @id @default(cuid())
  jti        String    @unique
  userId     String
  revoked    Boolean   @default(false)
  lastActive DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ArifPayment {
  id            String    @id
  sessionId     String    @unique
  transactionId String?
  billId        String
  amount        Decimal   @db.Decimal(12, 2)
  status        String    @default("PENDING")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime
  Agreement     Agreement @relation(fields: [billId], references: [id])
}


model YagoutPayment {
  id              String   @id @default(cuid())
  orderNo         String   @unique // The unique 'order_no' generated via randomBytes
  meId            String   // The Merchant ID used for this txn
  billId          String
  amount          Decimal  @db.Decimal(12, 2)
  currency        String   @default("ETB")
  status          String   @default("PENDING") // PENDING, SUCCESSFUL, FAILED, TIMEOUT
  
  // References returned by Yagout callback
  agRef           String?  @unique // Aggregator Reference
  pgRef           String?  @unique // Payment Gateway Reference
  
  // Response metadata
  resCode         String?  // Response code (e.g., "0")
  resMessage      String?  // Friendly message from Yagout
  
  // Audit data
  rawResponse     Json?    // Stores the full decrypted JSON object for deep tracing
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  bill            Bill     @relation(fields: [billId], references: [id], onDelete: Cascade)

  @@index([billId])
  @@index([orderNo])
}

enum BillStatus {
  Pending
  Paid
  Overdue
  PendingVerification
}

enum ChangeRequestStatus {
  Pending
  Approved
  Rejected
}

enum BuildingStatus {
  Pending
  Active
  Rejected
  Inactive
}

enum UserStatus {
  Active
  Inactive
}

enum TenantStatus {
  Active
  Inactive
}

enum AgreementStatus {
  Pending
  Active
  Inactive
  Expired
  Canceled
  Rejected
}
